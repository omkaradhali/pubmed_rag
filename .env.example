# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# ─── NCBI ────────────────────────────────────────────────────────────────────
# Free at https://www.ncbi.nlm.nih.gov/account/
# Without key: 3 req/sec. With key: 10 req/sec.
NCBI_API_KEY=your_ncbi_api_key_here

# ─── Vector store ─────────────────────────────────────────────────────────────
# chroma   — embedded ChromaDB, zero config, right for local dev and OSS use (default)
# qdrant   — Qdrant, right for production; requires QDRANT_URL below
VECTOR_STORE_BACKEND=chroma

# ChromaDB persistence path (used when VECTOR_STORE_BACKEND=chroma)
CHROMA_PERSIST_DIR=./data/chroma_db

# Qdrant connection (used when VECTOR_STORE_BACKEND=qdrant)
# Local Docker:   QDRANT_URL=http://qdrant:6333
# Qdrant Cloud:   QDRANT_URL=https://<cluster>.cloud.qdrant.io
# QDRANT_URL=
# QDRANT_API_KEY=

# ─── HuggingFace ─────────────────────────────────────────────────────────────
# Optional but recommended. Without it, the model version check is rate-limited
# to 1,000 requests/hour per IP (vs 5,000 with a token).
# Free at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# ─── Embedding provider ───────────────────────────────────────────────────────
# miniml   — all-MiniLM-L6-v2, local, free, 256-token limit (default)
# bge      — BAAI/bge-large-en-v1.5, local, free, 1024-dim, 512-token limit (stronger)
# medcpt   — MedCPT, local, free, biomedical-specific, 512-token limit
# openai   — text-embedding-3-small, $0.02/1M tokens, 8191-token limit (production)
# NOTE: changing this requires re-embedding the corpus + rebuilding the vector store.
EMBEDDING_PROVIDER=miniml

# ─── Reranker (cross-encoder second stage, v0.2) ──────────────────────────────
# Reranks the dense shortlist by joint (query, chunk) relevance — the main lever
# on retrieval ranking quality. Set RERANK_ENABLED=false for dense-only.
RERANK_ENABLED=true
# ncbi/MedCPT-Cross-Encoder — PubMedBERT cross-encoder, free, local, 512 tokens.
RERANK_MODEL=ncbi/MedCPT-Cross-Encoder
# Child candidates shortlisted by the bi-encoder before reranking.
RERANK_POOL=30

# ─── LLM provider ─────────────────────────────────────────────────────────────
# ollama   — local Ollama server, free (default)
# haiku    — claude-haiku-4-5, fast and cheap ($0.003/query)
# sonnet   — claude-sonnet-4-6, best quality ($0.010/query) — production default
# openai   — requires OPENAI_API_KEY
LLM_PROVIDER=ollama

# Model name for the selected provider
# ollama:  llama3.1:8b
# haiku:   claude-haiku-4-5-20251001
# sonnet:  claude-sonnet-4-6
LLM_MODEL=llama3.1:8b

# Ollama base URL (only if not running on localhost)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic API key — required for LLM_PROVIDER=haiku or sonnet
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — required for LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
# https://platform.openai.com/account/api-keys
# OPENAI_API_KEY=sk-...

# ─── Corpus ──────────────────────────────────────────────────────────────────
# Specialty drives the PubMed MeSH search term.
# oncology   — "Neoplasms"[MeSH], ~1.5M abstracts over 10 years (default)
# pediatrics — "Pediatrics"[MeSH], ~500K abstracts over 10 years
# veterinary — "Veterinary Medicine"[MeSH], ~200K abstracts over 10 years
# cardiology — "Cardiovascular Diseases"[MeSH]
PUBMED_SPECIALTY=oncology

# How many years of literature to ingest on a full pipeline run.
# 10 → ~1.5M abstracts, ~$9 to embed (text-embedding-3-small), ~19 GB Qdrant storage
#  5 → ~750K abstracts, ~$4.50
#  2 → ~300K abstracts, ~$1.80
PUBMED_YEARS_BACK=10

# ─── Ingestion ────────────────────────────────────────────────────────────────
INGEST_BATCH_SIZE=500

# ─── Observability (Phase 2) ─────────────────────────────────────────────────
# Logfire — FastAPI request tracing and application health
# https://logfire.pydantic.dev
# LOGFIRE_TOKEN=

# Langfuse — RAG pipeline traces (query → retrieved chunks → LLM response → cost)
# Cloud:       https://cloud.langfuse.com (free tier: 50K observations/month)
# Self-hosted: set LANGFUSE_HOST to your instance URL
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. Defaults to localhost for dev.
# Set to your deployment domain before exposing the API publicly. Never use * in production.
# CORS_ORIGINS=http://localhost:3000,https://myapp.example.com

# ─── API server ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated static API keys for X-API-Key header auth.
# Leave empty (default) to disable auth — safe for local dev and trusted networks.
# Set before exposing the API publicly. Rotate by adding a new key, deploying,
# then removing the old one (zero-downtime rotation).
# API_KEYS=sk-your-key-here,sk-another-key-for-rotation
