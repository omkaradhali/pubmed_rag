# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# NCBI Entrez API key (free at https://www.ncbi.nlm.nih.gov/account/)
# Without a key: 3 requests/sec. With a key: 10 requests/sec.
NCBI_API_KEY=your_ncbi_api_key_here

# LLM provider: ollama (default, free), anthropic, or openai
LLM_PROVIDER=ollama

# Model name for the selected provider
# ollama:    llama3.1:8b (default)
# anthropic: claude-haiku-4-5-20251001
# openai:    gpt-4o-mini
LLM_MODEL=llama3.1:8b

# Ollama base URL (only needed if not running on localhost)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic API key — only required if LLM_PROVIDER=anthropic
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — only required if LLM_PROVIDER=openai
# https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# ChromaDB persistence path (relative to project root)
CHROMA_PERSIST_DIR=./data/chroma_db

# Number of abstracts to fetch during ingestion
INGEST_BATCH_SIZE=500
